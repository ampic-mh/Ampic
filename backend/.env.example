# Copiez ce fichier en .env et remplissez vos valeurs

# Adresse Gmail utilisée pour ENVOYER les emails
GMAIL_USER=votre.email@gmail.com

# Mot de passe d'application Google (pas votre mot de passe Gmail normal)
# Créez-en un ici : https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email qui recevra les messages du formulaire
RECIPIENT_EMAIL=safirbrahim91@gmail.com

# Origines autorisées pour le CORS (frontend URL)
ALLOWED_ORIGINS=http://localhost:5173

# Mode debug Flask (true en dev, false en prod)
FLASK_DEBUG=true
